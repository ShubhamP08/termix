        "read file",
        "cat file",
        "print file",
        "view file"
      ],
      "commands": {
        "linux": "cat filename.txt",
        "macos": "cat filename.txt",
        "windows": "type filename.txt"
      },
      "id": "rule_0031"
    },
    {
      "intent": "view file with line numbers",
