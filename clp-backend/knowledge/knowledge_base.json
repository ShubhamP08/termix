        "chown file",
        "change owner",
        "change file ownership"
      ],
      "commands": {
        "linux": "chown user:group filename",
        "macos": "chown user:group filename",
        "windows": "takeown /f filename"
      },
      "id": "rule_0049"
    },
    {
