{
  "version": "2.0.0",
  "description": "Cross-platform knowledge base for AI terminal agent. Each rule contains OS-specific commands for Linux, macOS, and Windows.",
  "supported_os": [
    "linux",
    "macos",
    "windows"
  ],
  "rules": [
    {
      "intent": "find biggest file",
      "description": "Find and display the largest file in the current directory",
      "examples": [
        "biggest file",
        "biggest file in this folder",
        "find largest file",
        "show largest file",
        "which file is biggest"
      ],
      "commands": {
        "linux": "ls -lhS | head -2",
        "macos": "ls -lhS | head -2",
        "windows": "dir | sort /r"
      },
      "id": "rule_biggest_file"
    },
    {
      "intent": "list files",
      "description": "List files in the current directory",
      "examples": [
        "list files",
        "show files",
        "what files are here",
        "show directory contents"
      ],
      "commands": {
        "linux": "ls",
        "macos": "ls",
        "windows": "dir"
      },
      "id": "rule_0000"
    },
    {
      "intent": "list all files including hidden",
      "description": "List all files including hidden files with details",
      "examples": [
        "show hidden files",
        "list all files",
        "ls -la",
        "show everything"
      ],
      "commands": {
        "linux": "ls -la",
        "macos": "ls -la",
        "windows": "dir /a"
      },
      "id": "rule_0001"
    },
    {
      "intent": "list files with size",
      "description": "List files with human-readable sizes",
      "examples": [
        "show file sizes",
        "list files with size",
        "ls -lh"
      ],
      "commands": {
        "linux": "ls -lh",
        "macos": "ls -lh",
        "windows": "dir"
      },
      "id": "rule_0002"
    },
    {
      "intent": "biggest file",
      "description": "Find and display the largest/biggest file in the current directory",
      "examples": [
        "biggest file",
        "biggest file in this folder",
        "find biggest file",
        "find largest file",
        "show largest file",
        "which file is biggest",
        "largest files first",
        "sort files by size"
      ],
      "commands": {
        "linux": "ls -lhS | head -2",
        "macos": "ls -lhS | head -2",
        "windows": "dir /o-s"
      },
      "id": "rule_0003"
    },
    {
      "intent": "list files sorted by date",
      "description": "List files sorted by modification time, newest first",
      "examples": [
        "newest files first",
        "sort files by date",
        "recent files"
      ],
      "commands": {
        "linux": "ls -lt",
        "macos": "ls -lt",
        "windows": "dir /o-d"
      },
      "id": "rule_0004"
    },
    {
      "intent": "list files recursively",
      "description": "List all files including inside subdirectories",
      "examples": [
        "list all files recursive",
        "show all subdirectory files"
      ],
      "commands": {
        "linux": "ls -R",
        "macos": "ls -R",
        "windows": "dir /s"
      },
      "id": "rule_0005"
    },
    {
      "intent": "list only directories",
      "description": "List only folders in the current directory",
      "examples": [
        "show only folders",
        "list directories only"
      ],
      "commands": {
        "linux": "ls -d */",
        "macos": "ls -d */",
        "windows": "dir /ad"
      },
      "id": "rule_0006"
    },
    {
      "intent": "print current directory",
      "description": "Show the full path of where you currently are",
      "examples": [
        "where am i",
        "current path",
        "show current directory",
        "pwd"
      ],
      "commands": {
        "linux": "pwd",
        "macos": "pwd",
        "windows": "cd"
      },
      "id": "rule_0007"
    },
    {
      "intent": "go to home directory",
      "description": "Navigate to the user home directory",
      "examples": [
        "go home",
        "navigate to home",
        "home directory"
      ],
      "commands": {
        "linux": "cd ~",
        "macos": "cd ~",
        "windows": "cd %USERPROFILE%"
      },
      "id": "rule_0008"
    },
    {
      "intent": "go up one directory",
      "description": "Go up one level in the folder tree",
      "examples": [
        "go back",
        "go up",
        "parent directory",
        "one level up"
      ],
      "commands": {
        "linux": "cd ..",
        "macos": "cd ..",
        "windows": "cd .."
      },
      "id": "rule_0009"
    },
    {
      "intent": "go up two directories",
      "description": "Go up two levels in the folder tree",
      "examples": [
        "go up two levels",
        "two directories back"
      ],
      "commands": {
        "linux": "cd ../..",
        "macos": "cd ../..",
        "windows": "cd ..\\.."
      },
      "id": "rule_0010"
    },
    {
      "intent": "go to previous directory",
      "description": "Switch back to the last visited directory",
      "examples": [
        "go back to previous folder",
        "last directory",
        "switch back"
      ],
      "commands": {
        "linux": "cd -",
        "macos": "cd -",
        "windows": "cd -"
      },
      "id": "rule_0011"
    },
    {
      "intent": "create empty file",
      "description": "Create a new empty file",
      "examples": [
        "make new file",
        "create file",
        "new empty file",
        "touch file"
      ],
      "commands": {
        "linux": "touch filename.txt",
        "macos": "touch filename.txt",
        "windows": "type nul > filename.txt"
      },
      "id": "rule_0012"
    },
    {
      "intent": "create file with content",
      "description": "Create a file and write text into it",
      "examples": [
        "create file with text",
        "write text to file",
        "echo to file"
      ],
      "commands": {
        "linux": "echo 'your text here' > filename.txt",
        "macos": "echo 'your text here' > filename.txt",
        "windows": "echo your text here > filename.txt"
      },
      "id": "rule_0013"
    },
    {
      "intent": "append text to file",
      "description": "Add text to the end of an existing file",
      "examples": [
        "add text to file",
        "append to file",
        "write more to file"
      ],
      "commands": {
        "linux": "echo 'your text' >> filename.txt",
        "macos": "echo 'your text' >> filename.txt",
        "windows": "echo your text >> filename.txt"
      },
      "id": "rule_0014"
    },
    {
      "intent": "create directory",
      "description": "Create a new folder",
      "examples": [
        "make folder",
        "create folder",
        "new directory",
        "mkdir"
      ],
      "commands": {
        "linux": "mkdir folder_name",
        "macos": "mkdir folder_name",
        "windows": "mkdir folder_name"
      },
      "id": "rule_0015"
    },
    {
      "intent": "create nested directories",
      "description": "Create a chain of nested folders at once",
      "examples": [
        "create nested folders",
        "mkdir -p",
        "make folder structure",
        "create subdirectories"
      ],
      "commands": {
        "linux": "mkdir -p parent/child/grandchild",
        "macos": "mkdir -p parent/child/grandchild",
        "windows": "mkdir parent\\child\\grandchild"
      },
      "id": "rule_0016"
    },
    {
      "intent": "create multiple directories",
      "description": "Create several folders at the same time",
      "examples": [
        "make multiple folders",
        "create several directories"
      ],
      "commands": {
        "linux": "mkdir dir1 dir2 dir3",
        "macos": "mkdir dir1 dir2 dir3",
        "windows": "mkdir dir1 & mkdir dir2 & mkdir dir3"
      },
      "id": "rule_0017"
    },
    {
      "intent": "copy file",
      "description": "Copy a file to a new location or name",
      "examples": [
        "copy file",
        "duplicate file",
        "cp file",
        "clone file"
      ],
      "commands": {
        "linux": "cp source.txt destination.txt",
        "macos": "cp source.txt destination.txt",
        "windows": "copy source.txt destination.txt"
      },
      "id": "rule_0018"
    },
    {
      "intent": "copy file to directory",
      "description": "Copy a file into a specific folder",
      "examples": [
        "copy file to folder",
        "cp to directory"
      ],
      "commands": {
        "linux": "cp file.txt /path/to/destination/",
        "macos": "cp file.txt /path/to/destination/",
        "windows": "copy file.txt C:\\path\\to\\destination\\"
      },
      "id": "rule_0019"
    },
    {
      "intent": "copy directory",
      "description": "Copy an entire folder and its contents",
      "examples": [
        "copy folder",
        "duplicate directory",
        "cp -r",
        "copy folder recursively"
      ],
      "commands": {
        "linux": "cp -r source_folder/ destination_folder/",
        "macos": "cp -r source_folder/ destination_folder/",
        "windows": "xcopy source_folder destination_folder /e /i"
      },
      "id": "rule_0020"
    },
    {
      "intent": "copy multiple files to directory",
      "description": "Copy multiple files into a folder",
      "examples": [
        "copy many files",
        "cp multiple files",
        "copy several files"
      ],
      "commands": {
        "linux": "cp file1.txt file2.txt /destination/",
        "macos": "cp file1.txt file2.txt /destination/",
        "windows": "copy file1.txt file2.txt C:\\destination\\"
      },
      "id": "rule_0021"
    },
    {
