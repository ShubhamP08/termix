        "case insensitive search",
        "find text ignore case"
      ],
      "commands": {
        "linux": "grep -i 'search_term' filename.txt",
        "macos": "grep -i 'search_term' filename.txt",
        "windows": "findstr /i 'search_term' filename.txt"
      },
      "id": "rule_0046"
    },
    {
      "intent": "make file executable",
      "description": "Add execute permission to a file",
