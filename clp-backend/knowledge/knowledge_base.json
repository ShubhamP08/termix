      "description": "Move a file to a different directory",
      "examples": [
        "move file",
        "relocate file",
        "mv file",
        "send file to folder"
      ],
      "commands": {
        "linux": "mv file.txt /path/to/destination/",
        "macos": "mv file.txt /path/to/destination/",
        "windows": "move file.txt C:\\path\\to\\destination\\"
      },
      "id": "rule_0022"
    },
    {
