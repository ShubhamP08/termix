        "bottom of file"
      ],
      "commands": {
        "linux": "tail filename.txt",
        "macos": "tail filename.txt",
        "windows": "powershell Get-Content filename.txt -Tail 10"
      },
      "id": "rule_0035"
    },
    {
      "intent": "view last n lines of file",
      "description": "Show the last N lines of a file",
      "examples": [
        "last 20 lines",
        "tail -n",
        "bottom n lines"
      ],
      "commands": {
        "linux": "tail -n 20 filename.txt",
        "macos": "tail -n 20 filename.txt",
        "windows": "powershell Get-Content filename.txt -Tail 20"
      },
      "id": "rule_0036"
    },
    {
      "intent": "follow file output live",
      "description": "Watch a file for live updates, useful for monitoring logs",
      "examples": [
        "watch log file",
        "live file output",
        "monitor log",
        "follow file"
      ],
      "commands": {
        "linux": "tail -f filename.log",
        "macos": "tail -f filename.log",
        "windows": "powershell Get-Content filename.log -Wait"
      },
      "id": "rule_0037"
    },
    {
      "intent": "scroll through file",
      "description": "View file contents page by page",
      "examples": [
        "page through file",
        "scroll file",
        "read large file",
        "less file"
      ],
      "commands": {
        "linux": "less filename.txt",
        "macos": "less filename.txt",
        "windows": "more filename.txt"
      },
      "id": "rule_0038"
    },
    {
      "intent": "find file by name",
      "description": "Search for a file by name",
      "examples": [
        "find file",
        "search for file",
        "locate file",
        "where is file"
      ],
      "commands": {
        "linux": "find . -name 'filename.txt'",
        "macos": "find . -name 'filename.txt'",
        "windows": "dir filename.txt /s"
      },
      "id": "rule_0039"
    },
    {
      "intent": "find files by extension",
      "description": "Find all files with a specific extension",
      "examples": [
        "find all python files",
        "find all txt files",
        "search by extension"
      ],
      "commands": {
        "linux": "find . -name '*.py'",
        "macos": "find . -name '*.py'",
        "windows": "dir *.py /s"
      },
      "id": "rule_0040"
    },
    {
      "intent": "find files larger than size",
      "description": "Find files larger than a specific size",
      "examples": [
        "find large files",
        "files bigger than 100mb",
        "find -size"
      ],
      "commands": {
        "linux": "find . -size +100M",
        "macos": "find . -size +100M",
        "windows": "powershell Get-ChildItem -Recurse | Where-Object {$_.Length -gt 100MB}"
      },
      "id": "rule_0041"
    },
    {
      "intent": "find files modified recently",
      "description": "Find files modified in the last 7 days",
      "examples": [
        "find recent files",
        "files changed this week",
        "find -mtime"
      ],
      "commands": {
        "linux": "find . -mtime -7",
        "macos": "find . -mtime -7",
        "windows": "powershell Get-ChildItem -Recurse | Where-Object {$_.LastWriteTime -gt (Get-Date).AddDays(-7)}"
      },
      "id": "rule_0042"
    },
    {
      "intent": "find empty files",
      "description": "Find all empty files in the current directory",
      "examples": [
        "find empty files",
        "list empty files"
      ],
      "commands": {
        "linux": "find . -empty",
        "macos": "find . -empty",
        "windows": "powershell Get-ChildItem -Recurse | Where-Object {$_.Length -eq 0}"
      },
      "id": "rule_0043"
    },
    {
