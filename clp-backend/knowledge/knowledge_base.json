        "show permissions",
        "check file permissions"
      ],
      "commands": {
        "linux": "ls -l filename",
        "macos": "ls -l filename",
        "windows": "icacls filename"
      },
      "id": "rule_0050"
    },
    {
      "intent": "check disk usage",
      "description": "Show how much disk space is used and free",
      "examples": [
        "disk space",
        "how much space left",
        "drive usage",
        "check disk",
        "df -h"
      ],
      "commands": {
        "linux": "df -h",
        "macos": "df -h",
        "windows": "wmic logicaldisk get size,freespace,caption"
      },
      "id": "rule_0051"
    },
    {
      "intent": "check folder size",
      "description": "Show the total size of a directory",
      "examples": [
        "folder size",
        "how big is folder",
        "du -sh",
        "directory size"
      ],
      "commands": {
        "linux": "du -sh folder_name/",
        "macos": "du -sh folder_name/",
        "windows": "powershell (Get-ChildItem folder_name -Recurse | Measure-Object -Property Length -Sum).Sum / 1MB"
      },
      "id": "rule_0052"
    },
    {
      "intent": "check size of all folders",
      "description": "Show size of every subfolder in current directory",
      "examples": [
        "size of all folders",
        "list folder sizes"
      ],
      "commands": {
        "linux": "du -sh */",
        "macos": "du -sh */",
        "windows": "powershell Get-ChildItem | ForEach-Object { $_ | Add-Member -NotePropertyName Size -NotePropertyValue (Get-ChildItem $_.FullName -Recurse | Measure-Object -Property Length -Sum).Sum -PassThru } | Select-Object Name, Size"
      },
      "id": "rule_0053"
    },
    {
      "intent": "check file size",
      "description": "See how large a specific file is",
      "examples": [
        "how big is file",
        "file size",
        "check size of file"
      ],
      "commands": {
        "linux": "ls -lh filename",
        "macos": "ls -lh filename",
        "windows": "powershell (Get-Item filename).Length / 1KB"
      },
      "id": "rule_0054"
    },
    {
      "intent": "create symbolic link",
