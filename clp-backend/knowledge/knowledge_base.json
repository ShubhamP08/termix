        "make executable",
        "chmod +x",
        "give execute permission",
        "run permission"
      ],
      "commands": {
        "linux": "chmod +x filename.sh",
        "macos": "chmod +x filename.sh",
        "windows": "N/A - Windows uses file associations instead of execute bits"
      },
      "id": "rule_0047"
    },
    {
