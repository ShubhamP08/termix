      "description": "Rename a file",
      "examples": [
        "rename file",
        "change file name",
        "rename"
      ],
      "commands": {
        "linux": "mv old_name.txt new_name.txt",
        "macos": "mv old_name.txt new_name.txt",
        "windows": "ren old_name.txt new_name.txt"
      },
      "id": "rule_0023"
    },
    {
      "intent": "rename directory",
      "description": "Rename a folder",
      "examples": [
