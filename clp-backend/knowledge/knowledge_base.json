        "head -n",
        "top n lines of file"
      ],
      "commands": {
        "linux": "head -n 20 filename.txt",
        "macos": "head -n 20 filename.txt",
        "windows": "powershell Get-Content filename.txt -TotalCount 20"
      },
      "id": "rule_0034"
    },
    {
      "intent": "view last lines of file",
      "description": "Show the last 10 lines of a file",
      "examples": [
        "show end of file",
