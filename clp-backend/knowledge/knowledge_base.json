        "linux": "cat -n filename.txt",
        "macos": "cat -n filename.txt",
        "windows": "findstr /n . filename.txt"
      },
      "id": "rule_0032"
    },
    {
      "intent": "view first lines of file",
      "description": "Show the first 10 lines of a file",
      "examples": [
        "show top of file",
        "head file",
