{
  "version": "1.1.0",
  "description": "Deterministic-first knowledge base for a local NL-to-command terminal assistant. Maps natural language intents to safe, predictable shell commands across Linux, macOS, and Windows. App launching uses placeholder-based generic rules (open_app, open_app_in_current_dir) combined with a deterministic allowlist in application code — <app_name> must be validated against a permitted-apps list before execution. Only OS-native system apps (terminal, file manager, calculator) use direct hardcoded commands due to unreliable generic launching.",
  "rules": [
    {
      "id": "fs_list_files",
      "intent": "list files in current directory",
      "examples": [
        "list files",
        "show files",
        "what's in this folder",
        "ls",
        "show directory contents",
        "list all files here"
      ],
      "description": "List files and folders in the current directory.",
      "commands": {
        "linux": "ls -la",
        "macos": "ls -la",
        "windows": "dir"
      },
      "risk_level": "low",
      "requires_confirmation": false,
      "tags": [
        "filesystem",
        "list",
        "directory"
      ]
    },
    {
